# Novu docker-run environment.
# Source this file by running ./start-novu.sh or ./restart-novu.sh.

NOVU_PUBLIC_IP=192.168.124.2
NOVU_BIND_IP=0.0.0.0
NOVU_NETWORK=novu_default
NOVU_MONGO_DATA_DIR=/opt/novu/mongodb

NOVU_REDIS_CONTAINER_NAME=redis
NOVU_MONGODB_CONTAINER_NAME=mongodb
NOVU_API_CONTAINER_NAME=api
NOVU_WORKER_CONTAINER_NAME=worker
NOVU_WS_CONTAINER_NAME=ws
NOVU_DASHBOARD_CONTAINER_NAME=dashboard

NOVU_REDIS_IMAGE=redis:alpine
NOVU_MONGODB_IMAGE=mongo:8.0.17
NOVU_API_IMAGE=ghcr.io/novuhq/novu/api:3.17.0
NOVU_WORKER_IMAGE=ghcr.io/novuhq/novu/worker:3.17.0
NOVU_WS_IMAGE=ghcr.io/novuhq/novu/ws:3.17.0
NOVU_DASHBOARD_IMAGE=ghcr.io/novuhq/novu/dashboard:3.17.0

NOVU_API_HOST_PORT=13000
NOVU_WS_HOST_PORT=13002
NOVU_DASHBOARD_HOST_PORT=4000
NOVU_DASHBOARD_ALT_HOST_PORT=4200

# External LocalStack/S3 endpoint used by Novu. This script does not start a LocalStack container.
NOVU_S3_LOCAL_STACK_URL=http://192.168.124.2:4566

NOVU_NODE_ENV=local
NOVU_MONGO_ROOT_USERNAME=root
NOVU_MONGO_ROOT_PASSWORD=secret
NOVU_MONGO_DATABASE=novu-db
NOVU_MONGO_AUTH_SOURCE=admin
NOVU_MONGO_MIN_POOL_SIZE=5
NOVU_MONGO_MAX_POOL_SIZE=10

NOVU_REDIS_PASSWORD=
NOVU_REDIS_DB_INDEX=2
NOVU_REDIS_CACHE_SERVICE_HOST=

NOVU_S3_BUCKET_NAME=novu-local
NOVU_S3_REGION=us-east-1
NOVU_AWS_ACCESS_KEY_ID=test
NOVU_AWS_SECRET_ACCESS_KEY=test

NOVU_JWT_SECRET=3c03d6195380a3423722ecfe689f8a3f3b976c39006e10a7bee35e26428e3536
NOVU_STORE_ENCRYPTION_KEY=346e87a392b1bb45e7e6d7c115941001
NOVU_SECRET_KEY=e60404750f910f2d0694980be3471e1aaf314d4d5cca098cd72f99b2870cc4da
NOVU_SUBSCRIBER_WIDGET_JWT_EXPIRATION_TIME=15d

NOVU_SENTRY_DSN=
NOVU_NEW_RELIC_ENABLED=false
NOVU_NEW_RELIC_APP_NAME=NEW_RELIC_APP_NAME
NOVU_NEW_RELIC_LICENSE_KEY=NEW_RELIC_LICENSE_KEY

NOVU_API_CONTEXT_PATH=
NOVU_WS_CONTEXT_PATH=
NOVU_MONGO_AUTO_CREATE_INDEXES=true
NOVU_IS_API_IDEMPOTENCY_ENABLED=false
NOVU_IS_API_RATE_LIMITING_ENABLED=false
NOVU_IS_NEW_MESSAGES_API_RESPONSE_ENABLED=true
NOVU_IS_V2_ENABLED=true
NOVU_IS_SELF_HOSTED=true
NOVU_BROADCAST_QUEUE_CHUNK_SIZE=100
NOVU_MULTICAST_QUEUE_CHUNK_SIZE=100
NOVU_IS_EMAIL_INLINE_CSS_DISABLED=false
NOVU_IS_USE_MERGED_DIGEST_ID_ENABLED=false

NOVU_HEALTH_TIMEOUT_SECONDS=180
